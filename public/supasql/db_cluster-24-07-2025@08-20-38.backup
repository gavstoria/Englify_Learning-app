--
-- Name: profiles Authenticated users can view all profiles; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "Authenticated users can view all profiles" ON public.profiles FOR SELECT TO authenticated USING (true);


--
-- Name: class_assignments Class members can see assignments.; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "Class members can see assignments." ON public.class_assignments FOR SELECT USING ((EXISTS ( SELECT 1
   FROM public.class_members
  WHERE ((class_members.class_id = class_assignments.class_id) AND (class_members.user_id = auth.uid())))));


--
-- Name: games Public games are viewable by everyone.; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "Public games are viewable by everyone." ON public.games FOR SELECT USING (true);


--
-- Name: custom_game_questions Students can view assigned custom questions; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "Students can view assigned custom questions" ON public.custom_game_questions FOR SELECT USING ((EXISTS ( SELECT 1
   FROM public.class_assignments
  WHERE (class_assignments.game_id = custom_game_questions.game_id))));


--
-- Name: custom_game_word_bank Students can view assigned word banks; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "Students can view assigned word banks" ON public.custom_game_word_bank FOR SELECT USING ((EXISTS ( SELECT 1
   FROM public.custom_game_questions
  WHERE (custom_game_questions.id = custom_game_word_bank.question_id))));


--
-- Name: games Teachers can create custom games.; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "Teachers can create custom games." ON public.games FOR INSERT WITH CHECK ((( SELECT profiles.role
   FROM public.profiles
  WHERE (profiles.id = auth.uid())) = 'teacher'::text));


--
-- Name: class_assignments Teachers can delete assignments.; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "Teachers can delete assignments." ON public.class_assignments FOR DELETE USING ((( SELECT class_members.role
   FROM public.class_members
  WHERE ((class_members.class_id = class_assignments.class_id) AND (class_members.user_id = auth.uid()))) = 'teacher'::text));


--
-- Name: games Teachers can delete their own games.; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "Teachers can delete their own games." ON public.games FOR DELETE USING ((auth.uid() = teacher_id));


--
-- Name: class_assignments Teachers can insert assignments.; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "Teachers can insert assignments." ON public.class_assignments FOR INSERT WITH CHECK ((( SELECT class_members.role
   FROM public.class_members
  WHERE ((class_members.class_id = class_assignments.class_id) AND (class_members.user_id = auth.uid()))) = 'teacher'::text));


--
-- Name: custom_game_questions Teachers can manage questions for their games; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "Teachers can manage questions for their games" ON public.custom_game_questions USING ((( SELECT games.teacher_id
   FROM public.games
  WHERE (games.id = custom_game_questions.game_id)) = auth.uid())) WITH CHECK ((( SELECT games.teacher_id
   FROM public.games
  WHERE (games.id = custom_game_questions.game_id)) = auth.uid()));


--
-- Name: custom_game_word_bank Teachers can manage word banks for their games; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "Teachers can manage word banks for their games" ON public.custom_game_word_bank USING ((EXISTS ( SELECT 1
   FROM (public.custom_game_questions q
     JOIN public.games g ON ((q.game_id = g.id)))
  WHERE ((q.id = custom_game_word_bank.question_id) AND (g.teacher_id = auth.uid()))))) WITH CHECK ((EXISTS ( SELECT 1
   FROM (public.custom_game_questions q
     JOIN public.games g ON ((q.game_id = g.id)))
  WHERE ((q.id = custom_game_word_bank.question_id) AND (g.teacher_id = auth.uid())))));


--
-- Name: games Teachers can update their own games.; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "Teachers can update their own games." ON public.games FOR UPDATE USING ((auth.uid() = teacher_id));


--
-- Name: profiles Users can create their own profile; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "Users can create their own profile" ON public.profiles FOR INSERT TO authenticated WITH CHECK ((auth.uid() = id));


--
-- Name: user_activities Users can insert their own activities.; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "Users can insert their own activities." ON public.user_activities FOR INSERT WITH CHECK ((auth.uid() = user_id));


--
-- Name: profiles Users can update their own profile; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "Users can update their own profile" ON public.profiles FOR UPDATE TO authenticated USING ((auth.uid() = id)) WITH CHECK ((auth.uid() = id));


--
-- Name: user_activities Users can view their own activities.; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "Users can view their own activities." ON public.user_activities FOR SELECT USING ((auth.uid() = user_id));


